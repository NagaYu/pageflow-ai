{
  "manifest_version": 3,
  "name": "PageFlow AI",
  "version": "1.0.0",
  "description": "Zero copy-paste at work. Meeting-notes-to-form autofill / receipt-to-expense entry / dev-environment cleanup / calendar auto-blocking",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "clipboardRead"
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "https://api.anthropic.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PageFlow AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
